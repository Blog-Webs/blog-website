# Production environment — used by Vite during `npm run build` on Vercel.
# This file is safe to commit because it only contains the public backend URL
# (no secrets). Keep all API keys out of .env.production — use Vercel dashboard
# for secrets like VITE_GOOGLE_CLIENT_ID.

# Render backend — all API calls go here in production builds.
VITE_API_URL=https://httptechnex.onrender.com/api
VITE_SOCKET_URL=https://httptechnex.onrender.com
